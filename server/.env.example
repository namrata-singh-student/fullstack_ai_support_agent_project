PORT=5000
BACKEND_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173

# Cookie session (JWT in httpOnly cookie)
SESSION_JWT_SECRET=change_me_super_secret
SESSION_COOKIE_NAME=sp_session

# Scalekit (optional; only needed for real OAuth login flow)
SCALEKIT_ENVIRONMENT_URL=
SCALEKIT_CLIENT_ID=
SCALEKIT_CLIENT_SECRET=

# LLM provider keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional web search
TAVILY_API_KEY=

# Dev-only auth endpoints for local testing
E2E_TEST_MODE=true

